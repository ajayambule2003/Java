// Java code to remove a subList 
import java.util.*; 
 
public class GFG extends ArrayList<Integer> { 

	public static void main(String[] args) 
	{ 

		GFG arr = new GFG(); 

		arr.add(1); 
		arr.add(2); 
		arr.add(3); 
		arr.add(4); 
		arr.add(5); 
		arr.add(6); 
		arr.add(7); 
		arr.add(8); 
 
		System.out.println("Original List: "
						+ arr); 

		arr.removeRange(2, 4); 
		System.out.println("Final List: "
						+ arr); 
	} 
} 
